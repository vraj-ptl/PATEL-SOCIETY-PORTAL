# Environment Variables Example
# MongoDB Connection String
# Use your local MongoDB or a MongoDB Atlas cloud URI
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/society

# Session Secret (Choose a long random string)
SESSION_SECRET=your-secret-key-here
NODE_ENV=development

# Twilio SMS Credentials (Get these from twilio.com/console)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number
NODE_ENV=development
PORT=3000
